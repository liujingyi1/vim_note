From da348d1feee7eb5aece2cecaf58534291cd03efe Mon Sep 17 00:00:00 2001
From: YIGAOWU <thoughtworks.wu.wu@mercedes-benz.com>
Date: Wed, 15 Apr 2026 15:37:11 +0800
Subject: [PATCH] APRICOT-1043772 fix: Init system_server's ProcessState with
 4M in Zygote

---
 core/jni/com_android_internal_os_Zygote.cpp | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/core/jni/com_android_internal_os_Zygote.cpp b/core/jni/com_android_internal_os_Zygote.cpp
index fdb97f26f53f..b6dbc3a79439 100644
--- a/core/jni/com_android_internal_os_Zygote.cpp
+++ b/core/jni/com_android_internal_os_Zygote.cpp
@@ -89,6 +89,8 @@
 //FLYME: for sched-opt {@
 #include <sched.h>
 //@}
+#include <binder/ProcessState.h>
+
 #if defined(__BIONIC__)
 extern "C" void android_reset_stack_guards();
 #endif
@@ -2207,6 +2209,12 @@ static void SpecializeCommon(JNIEnv* env, uid_t uid, gid_t gid, jintArray gids,
         if (selinux_android_setcon(kSystemServerLabel) != 0) {
             fail_fn(CREATE_ERROR("selinux_android_setcon(%s)", kSystemServerLabel));
         }
+
+        // Init SystemServer's ProcessState here, before CallPostForkChildHooks.
+        constexpr size_t kSystemServerBinderVmSize = 4 * 1024 * 1024;
+        size_t mmapSize = kSystemServerBinderVmSize - (sysconf(_SC_PAGE_SIZE) * 2);
+        ALOGI("System server ProcessState is initialized with %zu mmapSize", mmapSize);
+        android::ProcessState::initWithMmapSize(mmapSize);
     }
 
     if (is_child_zygote) {
