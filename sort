void swap(int a[], int m, int n) {
    int temp = a[m];
    a[m] = a[n];
    a[n] = temp;
}

void swap(char a[], int m, int n) {
    int temp = a[m];
    a[m] = a[n];
    a[n] = temp;
}

堆排序
void HeapSort(int arr[], int n) {

    if (n < 2) return;

    for (int i = n - 1; i > 0; i--) {

        for (int top = (i + 1) / 2 - 1; top >= 0; top--) {
            int left = ((top+1) * 2) - 1;
            int right = (top + 1) * 2;

            if (arr[left] > arr[top]) {
                swap(arr, left, top);
            }
            if (right <= i && arr[right] > arr[top]) {
                swap(arr, right, top);
            }
        }

        swap(arr, i, 0);
    }
}

//打印数组的所有排列组合
void permutation(char list[], int start, int end) {
    if (start == end) {
        for (int i = 0; i <= end; i++) {
            printf("%c ", list[i]);
        }
        printf("\n ");
        return;
    }

    for (int i = start; i <= end; i++) {
        swap(list, start, i);
        permutation(list, start+1, end);
        swap(list, start, i);
    }
}

